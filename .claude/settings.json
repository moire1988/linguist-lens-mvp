{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": true,
  "respectGitignore": true,
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npm test:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vercel:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(node:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(lsof:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.production)",
      "Write(package-lock.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Applications/MAMP/htdocs/linguist-lens-mvp/.claude/hooks/protect-env.sh"
          }
        ]
      }
    ]
  }
}
